NOTE: We cant query forign key relations more than 5 levels from root in case of child to parent relation query

// Child to parent in the custom lookup : search filed name in lookup field
SELECT Id, Account.Name, Primary_Contact__c FROM Contact
SELECT Id, Account.Name, Primary_Contact__c,Primary_Contact__r.Name, Primary_Contact__r.Account.Name FROM Contact

//Parent to child query : search child name in lookup field , where clauses in inner querys are limited to inner querys , 
  on outer query are applicable to full query result
SELECT Id, Name, (SELECT Id, Name, Email FROM Contacts WHERE Email <>null), (SELECT Id, CaseNumber FROM Cases WHERE IsClosed=False), (SELECT
Id, Name, Account__c FROM Invoice__r) FROM Account

//We can write a query inside a child query as well in case if parent to child relation
// here we are fetching account's contacts , then those contact's cases as well , like wise we can do 5 deep querys in child querys

SELECT Id, Name, (SELECT Id, Name, Email, (SELECT Id, CaseNumber FROM Cases) FROM Contacts WHERE Email <> null), (SELECT Id, CaseNumber FROM
Cases WHERE IsClosed=False), (SELECT Id, Name, Account__c FROM
Invoice__r) FROM Account

