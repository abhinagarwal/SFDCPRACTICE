//Polymorphic query , who id (lead , contact) for task and what ID other objects except leasd and contacts (Oppt account  etc)

Select ID , Who.name , Who.Email , Who.phone , Who.company , WhatId , Subject , ActivityDate , Status , Priority , Description form Task

// in the above query WHO's name email campany are in both lead and contact ,but company is only in  contact so query will give error as field should be in
// both who object as WHO Id on the task can be of contact or of Lead
//so for this uncertainity we use poly morphic query

SELECT Id , TYPEOF WHO 
                  WHEN Contact THEN Id , Name , Email , AccountId
                  WHEN Lead THEN Id , Name , Company , AnnualRevenue
                  END,
                  WhatId, Subject , ActivityDate , Status , Priority , Description
                  FROM Task
            

